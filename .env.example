PORT=3000
DATA_DIR=/app/data
NODE_ENV=production
SESSION_COOKIE_SECURE=true
ADMIN_SESSION_TTL_SECONDS=28800

ADMIN_API_KEY=replace-with-admin-key
SESSION_SIGNING_KEY=replace-with-session-signing-key

TEAM9_API_BASE_URL=https://api.team9.ai/api
TEAM9_APP_BASE_URL=https://app.team9.ai
TEAM9_AUTH_TOKEN=replace-with-team9-access-token
TEAM9_REFRESH_TOKEN=replace-with-team9-refresh-token
TEAM9_TENANT_ID=replace-with-team9-tenant-id
